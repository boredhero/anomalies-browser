server {
    server_name anomalies.martinospizza.dev;

    # Proxy everything to the magic-eyes API (running locally via Docker)
    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Large responses for GeoJSON exports
        proxy_buffering off;
        proxy_read_timeout 300s;
    }

    # WebSocket support for job progress
    location /ws/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 86400s;
    }

    listen 80;
    # SSL will be added by certbot
}
